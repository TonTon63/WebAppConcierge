@model List<(string Rol, int Cantidad)>
@{
    ViewData["Title"] = "Cantidad de Usuarios por Rol";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bar-chart-fill me-2 text-primary"></i>Cantidad de Usuarios por Rol</h2>
        <div>
            <a asp-action="ExportarCantidadUsuariosPorRol" class="btn btn-success">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> Exportar a Excel
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover shadow-sm align-middle">
                <thead class="table-info">
                    <tr>
                        <th>Rol</th>
                        <th class="text-center">Cantidad de Usuarios</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.Rol == "Administrador")
                                {
                                    <span class="badge bg-danger">@item.Rol</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Rol</span>
                                }
                            </td>
                            <td class="text-center fw-bold">@item.Cantidad</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle me-2"></i>No hay datos disponibles para mostrar.
        </div>
    }
</div>

