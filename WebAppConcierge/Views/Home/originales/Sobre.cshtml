@{
    ViewData["Title"] = "Sobre Concierge Costa Rica";
}

<!-- Hero -->
<div class="container-fluid px-0">
    <div class="hero-banner position-relative text-white text-center d-flex align-items-center justify-content-center"
         style="background-image: url('/images/Principal/background.jpg'); background-size: cover; background-position: center; height: 450px;">
        <div class="overlay position-absolute w-100 h-100" style="background-color: rgba(0,0,0,0.6); top: 0; left: 0;"></div>
        <div class="position-relative z-1">
            <h1 class="display-4 fw-bold" data-aos="fade-down">Conoce a Nuestro Equipo</h1>
            <p class="lead" data-aos="fade-up">Descubre a las personas detrás de Concierge Costa Rica y nuestro compromiso con la excelencia en el servicio personalizado.</p>
        </div>
    </div>
</div>

<!-- Nuestra Empresa -->
<section class="py-5 text-dark" style="background-color: #fff3cd;">
    <!-- Amarillo suave -->
    <div class="container" style="max-width: 1000px;">
        <h2 class="fw-bold mb-4 text-center text-warning" data-aos="fade-up">Sobre Nuestra Empresa</h2>
        <p class="lead text-muted" data-aos="fade-up">
            Concierge Costa Rica es una empresa de servicios concierge que nace de la pasión y visión compartida de tres amigos con un fuerte compromiso por brindar experiencias únicas y soluciones personalizadas a nuestros clientes.
        </p>
        <p class="text-muted" data-aos="fade-up">
            Con años de experiencia en el mundo de la hospitalidad, el servicio al cliente, gestión y logística empresarial, decidimos unir nuestras fuerzas para crear un negocio basado en la confianza, la dedicación y la atención al detalle.
        </p>
        <p class="text-muted" data-aos="fade-up">
            Nos especializamos en ofrecer una amplia gama de servicios no solo en Costa Rica, sino en otros destinos claves. Desde la organización de transporte privado, chef en casa, reservas y eventos especiales, hasta la gestión de tareas cotidianas que hacen la vida más fácil y placentera.
        </p>
        <p class="text-muted" data-aos="fade-up">
            Nuestra empresa es más que un negocio; es una extensión de nuestra amistad y compromiso por ofrecer un servicio excepcional que simplifique la vida de quienes confían en nosotros.
        </p>
    </div>
</section>

<!-- Nuestro Equipo -->
<section class="py-5 text-dark" style="background-color: #d4f9f3;">
    <!-- Aqua -->
    <div class="container" style="max-width: 1000px;">
        <h2 class="fw-bold mb-3 text-center text-info" data-aos="fade-down">Conoce a Nuestro Equipo</h2>
        <p class="lead text-muted text-center mb-5" data-aos="fade-up">
            Descubre a las personas detrás de Concierge Costa Rica y nuestro compromiso con la excelencia en el servicio personalizado.
        </p>

        <div class="row text-center">
            <div class="col-md-4 mb-4" data-aos="zoom-in">
                <img src="~/images/SobreNosotros/equipo1.jpg" class="img-fluid rounded-circle mb-3 shadow" style="width: 180px; height: 180px; object-fit: cover;" alt="Miembro 1">
                <h5 class="fw-bold text-success">Alejandro Bogantes</h5>
                <p class="text-muted">Director General</p>
            </div>
            <div class="col-md-4 mb-4" data-aos="zoom-in" data-aos-delay="100">
                <img src="~/images/SobreNosotros/equipo2.jpg" class="img-fluid rounded-circle mb-3 shadow" style="width: 180px; height: 180px; object-fit: cover;" alt="Miembro 2">
                <h5 class="fw-bold text-success">Natali Lacayo</h5>
                <p class="text-muted">Gestora de Experiencias</p>
            </div>
            <div class="col-md-4 mb-4" data-aos="zoom-in" data-aos-delay="200">
                <img src="~/images/SobreNosotros/equipo3.jpg" class="img-fluid rounded-circle mb-3 shadow" style="width: 180px; height: 180px; object-fit: cover;" alt="Miembro 3">
                <h5 class="fw-bold text-success">Anthony Vásquez</h5>
                <p class="text-muted">Especialista en Logística</p>
            </div>
        </div>
    </div>
</section>
<!-- Valores -->
<section class="py-5 text-dark" style="background-color: #ffe6e6;">
    <div class="container" style="max-width: 1000px;">
        <div class="row align-items-center" data-aos="fade-right">
            <div class="col-md-6">
                <img src="~/images/Principal/values.jpg" alt="Valores Concierge" class="img-fluid rounded shadow">
            </div>
            <div class="col-md-6">
                <h3 class="fw-semibold mb-3 text-warning">Nuestros Valores</h3>
                <ul class="list-unstyled fs-5">
                    <li><i class="bi bi-star-fill text-warning me-2"></i> Excelencia en el servicio</li>
                    <li><i class="bi bi-shield-lock-fill text-warning me-2"></i> Confidencialidad absoluta</li>
                    <li><i class="bi bi-heart-fill text-warning me-2"></i> Pasión por los detalles</li>
                    <li><i class="bi bi-lightbulb-fill text-warning me-2"></i> Innovación constante</li>
                    <li><i class="bi bi-people-fill text-warning me-2"></i> Empatía y compromiso</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Testimonios -->
<section class="py-5 text-dark" style="background-color: #e0f7fa;">
    <div class="container" style="max-width: 1000px;">
        <h3 class="fw-bold text-info text-center mb-5" data-aos="zoom-in">Testimonios de Clientes</h3>
        <div class="row">
            <div class="col-md-4 mb-4" data-aos="fade-up">
                <div class="card border-0 shadow rounded p-3 h-100 bg-white">
                    <p class="fst-italic text-muted">“La mejor experiencia de mi vida. Concierge Costa Rica se encargó de todo, desde la llegada al aeropuerto hasta una cena romántica en la playa.”</p>
                    <div class="fw-bold mt-3">– Laura G., México</div>
                </div>
            </div>
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card border-0 shadow rounded p-3 h-100 bg-white">
                    <p class="fst-italic text-muted">“Profesionalismo, puntualidad y un trato exquisito. Recomendadísimo para quienes buscan lo mejor en sus vacaciones.”</p>
                    <div class="fw-bold mt-3">– Marco R., Italia</div>
                </div>
            </div>
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card border-0 shadow rounded p-3 h-100 bg-white">
                    <p class="fst-italic text-muted">“Me ayudaron a conseguir entradas VIP para un evento exclusivo en Tulum. Todo salió perfecto.”</p>
                    <div class="fw-bold mt-3">– Ana P., Costa Rica</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 text-center" style="background-color: #ccf2ff;">
    <div class="container" data-aos="zoom-in">
        <h4 class="mb-4">¿Listo para vivir una experiencia inolvidable?</h4>
        <a href="/Home/Contactar" class="btn btn-primary btn-lg px-5 py-2 shadow">Contáctanos</a>
    </div>
</section>

<!-- Estilos adicionales -->
<style>
    .hero-banner h1, .hero-banner p {
        text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.6);
    }

    .card p {
        font-size: 1.05rem;
    }
</style>
