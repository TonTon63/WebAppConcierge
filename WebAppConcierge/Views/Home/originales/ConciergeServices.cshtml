@{
    ViewData["Title"] = "Concierge Services";
}

<section class="services-section bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5 fw-bold text-primary" data-aos="fade-up">Nuestros Servicios Concierge</h2>

        <!-- Costa Rica -->
        <h3 class="text-primary mt-5 mb-4">Costa Rica</h3>
        <div class="row row-cols-1 row-cols-md-3 g-4">

            <!-- Autos VIP -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/transport.jpg" class="card-img-top" alt="Autos VIP">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Autos VIP</h5>
                        <p class="card-text text-muted">Ofrecemos traslados privados desde/hacia el aeropuerto y a los destinos más populares dentro y fuera de la ciudad, así como conductores por horas, días o semanas.</p>
                    </div>
                </div>
            </div>

            <!-- Jet Privado -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/jet.jpg" class="card-img-top" alt="Jet privado">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Jet Privado</h5>
                        <p class="card-text text-muted">Una opción eficiente para viajar con comodidad y puntualidad. Te ayudamos a encontrar el jet adecuado para tu itinerario.</p>
                    </div>
                </div>
            </div>

            <!-- Helicóptero -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/helicopter.jpg" class="card-img-top" alt="Helicóptero">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Helicóptero</h5>
                        <p class="card-text text-muted">Llega a tu destino con estilo y rapidez. Perfecto para evitar tráfico o disfrutar vistas panorámicas.</p>
                    </div>
                </div>
            </div>

            <!-- Yate Privado -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/yacht.jpg" class="card-img-top" alt="Yate privado">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Yate Privado</h5>
                        <p class="card-text text-muted">Relájate en el mar con un yate totalmente equipado, incluyendo comidas y bebidas a bordo.</p>
                    </div>
                </div>
            </div>

            <!-- Catamarán de Vela -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/catamaran.jpg" class="card-img-top" alt="Catamarán de vela">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Catamarán de Vela</h5>
                        <p class="card-text text-muted">Navega con comodidad y seguridad en excursiones diurnas o al atardecer.</p>
                    </div>
                </div>
            </div>

            <!-- Chef Privado -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/chef.jpg" class="card-img-top" alt="Chef privado">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Chef Privado</h5>
                        <p class="card-text text-muted">Disfrutá de una experiencia gourmet en tu villa, casa o apartamento. También ofrecemos catering y entrega de comida.</p>
                    </div>
                </div>
            </div>

            <!-- Compra de Artículos -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/groceries.jpg" class="card-img-top" alt="Compra de artículos">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Compra de Artículos</h5>
                        <p class="card-text text-muted">Abastecemos tu cocina antes de tu llegada o realizamos entregas cuando lo necesités.</p>
                    </div>
                </div>
            </div>

            <!-- Fast Track -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/fasttrack.jpg" class="card-img-top" alt="Fast Track">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Fast Track</h5>
                        <p class="card-text text-muted">Evita filas en el aeropuerto con asistencia personalizada en migración, aduanas y recogida de equipaje.</p>
                    </div>
                </div>
            </div>

            <!-- Arreglos Florales -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/flowers.jpg" class="card-img-top" alt="Arreglos florales">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Decoración y Arreglos Florales</h5>
                        <p class="card-text text-muted">Adornamos tu hogar o evento con arreglos florales únicos y frescos.</p>
                    </div>
                </div>
            </div>

            <!-- Profesor de Español -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/spanish.jpg" class="card-img-top" alt="Profesor de español">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Profesor de Español</h5>
                        <p class="card-text text-muted">Clases personalizadas para todos los niveles desde la comodidad de tu alojamiento.</p>
                    </div>
                </div>
            </div>

            <!-- Meet & Greet -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/greet.jpg" class="card-img-top" alt="Meet and Greet">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Recepción y Bienvenida</h5>
                        <p class="card-text text-muted">Recibimos a tus huéspedes, les mostramos la propiedad y aclaramos dudas para un check-in sin problemas.</p>
                    </div>
                </div>
            </div>

            <!-- Inspección de Propiedad -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/inspection.jpg" class="card-img-top" alt="Inspección de propiedad">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Inspección de Propiedad</h5>
                        <p class="card-text text-muted">Verificamos que todo esté en orden antes de tu llegada a la propiedad de alquiler.</p>
                    </div>
                </div>
            </div>

            <!-- Fotografía Profesional -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/photography.jpg" class="card-img-top" alt="Fotografía profesional">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Fotografía Profesional</h5>
                        <p class="card-text text-muted">Capturá tus mejores momentos con imágenes de alta calidad a cargo de fotógrafos expertos.</p>
                    </div>
                </div>
            </div>

            <!-- Bartender y Mixólogo -->
            <div class="col" data-aos="zoom-in">
                <div class="card h-100 shadow-lg border-0">
                    <img src="~/images/ConciergeServices/bartender.jpg" class="card-img-top" alt="Bartender">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold text-center">Servicios de Bartender y Mixólogo</h5>
                        <p class="card-text text-muted">Llevá tus eventos al siguiente nivel con cócteles personalizados preparados por expertos.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    .card:hover {
        transform: translateY(-5px);
        transition: 0.3s ease;
    }

    .card-img-top {
        height: 200px;
        object-fit: cover;
    }
</style>