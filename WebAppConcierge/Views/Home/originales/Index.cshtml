<!-- Presentación -->
<section class="container-fluid p-0" data-aos="fade-up">
    <div id="heroCarousel" class="carousel slide fullscreen-carousel" data-bs-ride="carousel">
        <div class="carousel-inner">

            <div class="carousel-item active position-relative">
                <img src="@Url.Content("~/images/img/img7.jpg")" class="d-block w-100" alt="Imagen 1" />
                <div class="carousel-caption d-flex flex-column justify-content-center align-items-center top-0 bottom-0 start-0 end-0">
                    <div class="caption-bg p-4 rounded">
                    <h1 class="display-4 fw-bold" data-aos="fade-down">Concierge Costa Rica</h1>
                    <p class="lead" data-aos="fade-up">Tu experiencia personalizada comienza aquí.</p>
                    </div>
                </div>
                   
            </div>

            <div class="carousel-item position-relative">
                <img src="@Url.Content("~/images/img/img8.jpg")" class="d-block w-100" alt="Imagen 2" />
                <div class="carousel-caption d-flex flex-column justify-content-center align-items-center top-0 bottom-0 start-0 end-0">
                    <h1 class="display-4 fw-bold" data-aos="fade-down">Concierge Costa Rica</h1>
                    <p class="lead" data-aos="fade-up">Tu experiencia personalizada comienza aquí.</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="@Url.Content("~/images/img/img9.png")" class="d-block w-100 rounded" alt="Imagen 3" />
                <div class="carousel-caption d-flex flex-column justify-content-center align-items-center top-0 bottom-0 start-0 end-0">
                    <h1 class="display-4 fw-bold" data-aos="fade-down">Concierge Costa Rica</h1>
                    <p class="lead" data-aos="fade-up">Tu experiencia personalizada comienza aquí.</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="@Url.Content("~/images/img/img6.jpg")" class="d-block w-100 rounded" alt="Imagen 4" />
                <div class="carousel-caption d-flex flex-column justify-content-center align-items-center top-0 bottom-0 start-0 end-0">
                    <h1 class="display-4 fw-bold" data-aos="fade-down">Concierge Costa Rica</h1>
                    <p class="lead" data-aos="fade-up">Tu experiencia personalizada comienza aquí.</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="@Url.Content("~/images/img/img5.jpg")" class="d-block w-100 rounded" alt="Imagen 5" />
                <div class="carousel-caption d-flex flex-column justify-content-center align-items-center top-0 bottom-0 start-0 end-0">
                    <h1 class="display-4 fw-bold" data-aos="fade-down">Concierge Costa Rica</h1>
                    <p class="lead" data-aos="fade-up">Tu experiencia personalizada comienza aquí.</p>
                </div>
            </div>

        </div>

        <!-- Controles de navegación -->
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <section class="intro-section text-white d-flex align-items-center" data-aos="fade-up">
        <div class="container text-center">
            <h2 class="mb-4">Tu experiencia personalizada en Costa Rica</h2>
            <p>
                En <strong>Concierge Costa Rica</strong> le ofrecemos un servicio élite para ayudarle a hacer sus reservaciones para restaurantes,
                comprar entradas para eventos, preparar las vacaciones soñadas, concertar lo necesario para
                sus actividades empresariales en el mundo entero, localizar artículos difíciles de encontrar,
                así como comprar y entregar regalos especiales. El costo de los bienes o servicios se factura
                a su tarjeta Platinum MasterCard.
            </p>
        </div>
    </section>
    
   
</section>
<!-- Servicios destacados -->
<section class="bg-white py-5">
    <div class="container">
        <h2 class="text-center mb-5 fw-bold" data-aos="zoom-in">Nuestros Servicios</h2>
        <div class="row row-cols-1 row-cols-md-2 g-5">
            <div class="col" data-aos="fade-right">
                <img src="~/images/servicios/general.jpg" class="img-fluid rounded shadow mb-3" alt="Asistencia general">
                <h4 class="fw-semibold">Asistencia general</h4>
                <p>Alquiler de automóviles y limusinas, tiendas especializadas, investigación de productos y más.</p>
            </div>
            <div class="col" data-aos="fade-left">
                <img src="~/images/servicios/cultural.jpg" class="img-fluid rounded shadow mb-3" alt="Información cultural">
                <h4 class="fw-semibold">Información cultural</h4>
                <p>Eventos, atracciones locales y extranjeras, normas de protocolo y etiqueta.</p>
            </div>
            <div class="col" data-aos="fade-right">
                <img src="~/images/servicios/restaurantes.jpg" class="img-fluid rounded shadow mb-3" alt="Restaurantes">
                <h4 class="fw-semibold">Recomendaciones de restaurantes</h4>
                <p>Reservas en restaurantes de lujo, información de menú, código de vestimenta y más.</p>
            </div>
            <div class="col" data-aos="fade-left">
                <img src="~/images/servicios/entretenimiento.jpg" class="img-fluid rounded shadow mb-3" alt="Entretenimiento">
                <h4 class="fw-semibold">Entretenimiento</h4>
                <p>Acceso a conciertos, teatro, ópera, museos y eventos deportivos.</p>
            </div>
            <div class="col" data-aos="fade-right">
                <img src="~/images/servicios/empresarial.jpg" class="img-fluid rounded shadow mb-3" alt="Empresarial">
                <h4 class="fw-semibold">Servicios empresariales</h4>
                <p>Traductores, intérpretes, alquiler de tecnología e información de negocios al viajar.</p>
            </div>
            <div class="col" data-aos="fade-left">
                <img src="~/images/servicios/golf.jpg" class="img-fluid rounded shadow mb-3" alt="Golf">
                <h4 class="fw-semibold">Recomendaciones de golf</h4>
                <p>Reservas y sugerencias en campos públicos y privados de ciudades principales.</p>
            </div>
            <div class="col" data-aos="fade-right">
                <img src="~/images/servicios/recreativo.jpg" class="img-fluid rounded shadow mb-3" alt="Recreativas">
                <h4 class="fw-semibold">Actividades recreativas</h4>
                <p>Paseos, deportes, visitas turísticas, referidos para gimnasios y más.</p>
            </div>
            <div class="col" data-aos="fade-left">
                <img src="~/images/servicios/regalos.jpg" class="img-fluid rounded shadow mb-3" alt="Regalos">
                <h4 class="fw-semibold">Coordinación de regalos</h4>
                <p>Flores, canastas, globos, regalos personalizados nacionales e internacionales.</p>
            </div>
            <div class="col" data-aos="zoom-in">
                <img src="~/images/servicios/articulos.jpg" class="img-fluid rounded shadow mb-3" alt="Artículos únicos">
                <h4 class="fw-semibold">Artículos únicos</h4>
                <p>Búsqueda de artículos difíciles de encontrar como arte, libros raros u objetos únicos.</p>
            </div>
        </div>
    </div>
</section>

<!-- Galería -->
<section class="gallery-section py-5 bg-dark" data-aos="zoom-in">
    <h2 class="text-center text-white mb-4">Galería</h2>
    <div id="conciergeCarousel" class="carousel slide shadow rounded w-75 mx-auto" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/Galeria/img1.jpg" class="d-block w-100 galeria-img" alt="Imagen 1">
            </div>
            <div class="carousel-item">
                <img src="~/images/Galeria/img2.jpg" class="d-block w-100 galeria-img" alt="Imagen 2">
            </div>
            <div class="carousel-item">
                <img src="~/images/Galeria/img3.jpg" class="d-block w-100 galeria-img" alt="Imagen 3">
            </div>
            <div class="carousel-item">
                <img src="~/images/Galeria/img4.jpg" class="d-block w-100 galeria-img" alt="Imagen 4">
            </div>
            <div class="carousel-item">
                <img src="~/images/Galeria/img5.jpg" class="d-block w-100 galeria-img" alt="Imagen 5">
            </div>
            <div class="carousel-item">
                <img src="~/images/Galeria/img6.jpg" class="d-block w-100 galeria-img" alt="Imagen 6">
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#conciergeCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
            <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#conciergeCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
            <span class="visually-hidden">Siguiente</span>
        </button>
    </div>
</section>


<!-- Contacto -->
<section class="contact-section text-white text-center d-flex align-items-center">
    <div class="container" data-aos="fade-up">
        <h2>¿Listo para comenzar?</h2>
        <p>Contáctanos para planear tu experiencia de lujo</p>
        <a href="/Home/Contactar" class="btn btn-light mt-3">Contáctenos</a>
    </div>
</section>

