@{
    ViewData["Title"] = "Panel de Administración";
}

<style>
    .sidebar {
        background: linear-gradient(180deg, #212f3c, #1c2833);
        color: #fff;
        min-height: 100vh;
        padding: 20px;
        width: 240px;
    }

        .sidebar h4 {
            color: #f4c542;
            margin-bottom: 2rem;
            font-weight: 700;
        }

        .sidebar .nav-link {
            color: #fdfefe;
            font-weight: 500;
            border-radius: 8px;
            padding: 10px 15px;
            transition: background-color 0.3s ease;
        }

            .sidebar .nav-link.active,
            .sidebar .nav-link:hover {
                background-color: #f4c542;
                color: #000 !important;
            }

    .card-panel {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 1rem;
    }

        .card-panel:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .card-panel i {
            color: #1abc9c;
        }

    @@media (max-width: 768px) {
        .sidebar

    {
        display: none;
    }

    }
</style>

<div class="d-flex">
    <!-- Sidebar -->
    <nav class="sidebar">
        <h4>Panel de Administración</h4>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a asp-controller="Usuarios" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")">
                    <i class="bi bi-people-fill me-2"></i>Usuarios
                </a>
            </li>
            <li class="nav-item mb-2">
                <a asp-controller="Reservas" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservas" ? "active" : "")">
                    <i class="bi bi-calendar-check me-2"></i>Reservas
                </a>
            </li>
            <li class="nav-item mb-2">
                <a asp-controller="Reportes" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reportes" ? "active" : "")">
                    <i class="bi bi-graph-up me-2"></i>Reportes
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1 p-4">
        <div class="row g-4">
            <div class="col-sm-6 col-lg-4">
                <div class="card text-center shadow-sm card-panel">
                    <div class="card-body">
                        <i class="bi bi-people-fill display-4 mb-3"></i>
                        <h5 class="card-title">Usuarios</h5>
                        <a asp-controller="Usuarios" asp-action="Index" class="btn btn-outline-primary mt-2">Administrar</a>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="card text-center shadow-sm card-panel">
                    <div class="card-body">
                        <i class="bi bi-calendar-check display-4 mb-3"></i>
                        <h5 class="card-title">Reservas</h5>
                        <a asp-controller="Reservas" asp-action="Index" class="btn btn-outline-primary mt-2">Ver Reservas</a>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="card text-center shadow-sm card-panel">
                    <div class="card-body">
                        <i class="bi bi-graph-up display-4 mb-3"></i>
                        <h5 class="card-title">Reportes</h5>
                        <a asp-controller="Reportes" asp-action="Index" class="btn btn-outline-primary mt-2">Ver Reportes</a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Requiere Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
